# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (rag.py โหลดผ่าน python-dotenv อัตโนมัติ)
#   cp .env.example .env

# LLM endpoint แบบ OpenAI-compatible + API key
LLM_BASE_URL=http://your-llm-endpoint/v1
LLM_API_KEY=sk-xxxxxxxx

# (ออปชัน) Ollama endpoint — ใช้เฉพาะตอนสลับ EMBED_MODEL เป็น paraphrase-multilingual
OLLAMA_BASE_URL=http://localhost:11434

# (ออปชัน) experiment tracking — ไม่ตั้ง = เก็บลง mlruns/ ในเครื่อง
# MLFLOW_TRACKING_URI=http://your-mlflow-server:5000/
# MLFLOW_EXPERIMENT=thai-law-rag-eval
#
# 🔐 ถ้า MLflow server ต้อง login: ตั้ง MLFLOW_TRACKING_USERNAME / MLFLOW_TRACKING_PASSWORD
#    เป็น env var ของ "ระบบปฏิบัติการ" — อย่าใส่ในไฟล์ .env เพราะเสี่ยงหลุดเข้า repo
#    Windows: setx MLFLOW_TRACKING_USERNAME "ชื่อผู้ใช้"    (ปิด-เปิด terminal ใหม่)

# (ออปชัน) ป้องกัน API ใน main.py — ไม่ตั้ง = ใครก็เรียกได้ (เหมาะกับ dev เท่านั้น)
# API_KEY=ตั้งค่าสุ่มยาว ๆ

# ═══ OCR ของบริษัท — ใช้เฉพาะตอนรัน eval/ocr_bench.py --engine company ═══
# ระบบหลักยังใช้ EasyOCR (local) อยู่ ไม่ตั้ง 2 ตัวนี้ก็ใช้งานได้ตามปกติ
# OCR_BASE_URL=https://<host ภายใน>:<port>        # ไม่ต้องมี /v3 ต่อท้าย โค้ดเติมเอง
# OCR_API_KEY=<คีย์ที่ได้จากทีมที่ดูแล service>    # service รับ Bearer token เท่านั้น
#
# (ออปชัน) ปรับได้ ถ้าไม่ตั้งจะใช้ค่าในวงเล็บ
# OCR_MODEL_NAME=qwen/qwen3.5-27b     # โมเดลอ่านภาพ
# OCR_PRE_ENGINE=tesseract            # เครื่อง pre-OCR
# OCR_VERIFY_SSL=1                    # (ค่าเริ่มต้น=ปิด เพราะ service ภายในใช้ self-signed cert)
# OCR_MAX_WAIT_SEC=7200               # รอผลนานสุดกี่วินาที
# OCR_PROMPT=...                      # ทับ prompt เริ่มต้น
#   ⚠️ prompt เริ่มต้นจงใจสั่ง "ห้ามแก้คำผิดตามบริบท" ต่างจาก prompt ต้นฉบับของบริษัท
#      เพราะกับตัวบทกฎหมาย ถ้าโมเดลเดาแทนเรา มันอาจเปลี่ยน "๕ ปี" เป็น "๑๐ ปี"
#      แล้วออกมาอ่านลื่นจนไม่มีอะไรส่อว่าผิด — ดูเหตุผลเต็มใน eval/ocr_bench.py

# (ออปชัน) override ค่าอื่น
# LLM_MODEL=google/gemma-4-26b-a4b-it
# EMBED_MODEL=text-embedding-ada-002
# RAG_RERANK=0                          # ปิด cross-encoder reranker (เร็วขึ้น แม่นลง)
# TOP_K=12                              # จำนวน chunk ที่ส่งให้ LLM ตอบ
